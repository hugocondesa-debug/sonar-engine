# ============================================================================
# SONAR v2 · Environment variables template
# ============================================================================
#
# Copy this file to .env and fill in actual values.
# .env is GITIGNORED — never commit.
#
# Each variable documented with:
#   - Whether required for MVP (Tier 1)
#   - Where to register
#   - Notes on usage

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------
SONAR_ENV=development          # development | staging | production
SONAR_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Default: SQLite file. Change to postgres://... if migrating later.
SONAR_DB_URL=sqlite:///data/sonar.db

# ----------------------------------------------------------------------------
# Tier 1 MVP — required API keys
# ----------------------------------------------------------------------------

# FRED (Federal Reserve St. Louis)
# Required. Free registration.
# Register: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=your_fred_api_key_here

# Trading Economics (shared subscription)
# Optional for MVP. Useful for EM coverage.
# Register: https://tradingeconomics.com/analytics/api.aspx
TRADING_ECONOMICS_KEY=

# ----------------------------------------------------------------------------
# Rate limits & retries (sensible defaults)
# ----------------------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=2.0
HTTP_USER_AGENT=SONAR/0.1 (+https://github.com/hugocondesa-debug/sonar)

# ----------------------------------------------------------------------------
# Pipeline orchestration
# ----------------------------------------------------------------------------
SONAR_PIPELINE_TZ=Europe/Lisbon
SONAR_PIPELINE_PARALLEL=false   # true for parallel connector fetching

# ----------------------------------------------------------------------------
# Tier 2 optional — enhanced coverage
# ----------------------------------------------------------------------------

# Bloomberg Terminal (if subscribed)
# BLOOMBERG_API_HOST=localhost
# BLOOMBERG_API_PORT=8194

# Refinitiv Eikon (if subscribed)
# REFINITIV_APP_KEY=

# Glassnode (for FCS crypto on-chain — already in FCS plan)
# GLASSNODE_API_KEY=

# ----------------------------------------------------------------------------
# Notifications
# ----------------------------------------------------------------------------

# Telegram (for pipeline alerts + editorial alerts)
# Create bot: message @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=sonar@7365capital.com
# SMTP_TO=hugo@7365capital.com

# ----------------------------------------------------------------------------
# Cloud storage (optional — for backups)
# ----------------------------------------------------------------------------

# Backblaze B2 (cheapest option — recommended)
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET=sonar-backups

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# S3_BACKUP_BUCKET=sonar-backups

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------
SONAR_ENABLE_ALERTS=false          # true to publish alerts via email/Telegram
SONAR_ENABLE_EDITORIAL=false       # true to generate daily editorial briefing
SONAR_ENABLE_API=false             # true to run FastAPI server
SONAR_ENABLE_DASHBOARD=false       # true to serve Streamlit dashboard

# ----------------------------------------------------------------------------
# Development
# ----------------------------------------------------------------------------
SONAR_DEBUG=false                  # extra debug logging
SONAR_PROFILE=false                # enable profiler
SONAR_DRY_RUN=false                # don't write to DB

# ----------------------------------------------------------------------------
# Admin
# ----------------------------------------------------------------------------
SONAR_VERSION=0.1.0
SONAR_MAINTAINER=hugo@7365capital.com
